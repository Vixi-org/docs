        ]
      },
      {
        "group": "Edit & publish",
        "pages": [
          "editing",
          "publishing"
        ]
      },
      {
        "group": "Learners & growth",
        "pages": [
          "learners",
          "earnings",
          "premium",
          "marketing"
        ]
      },
      {
        "group": "Author verification",
        "pages": [
          "author-verification"
        ]
      },
